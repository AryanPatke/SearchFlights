# SearchFlights configuration
# Copy to .env and adjust as needed.

# Comma-separated IATA codes scanned when --destination is omitted.
SF_DEFAULT_DESTINATIONS_CSV=BKK,CMB,KUL,SIN,DXB,HKT,SGN,GOI,DEL,CCU,DOH,NRT,LHR,CDG,FRA,AMS,MAD,BCN,FCO,MXP,BER,MUC,VIE,ZRH,GVA,LIS,CPH,OSL,ARN,HEL,DUB,BRU,WAW,PRG,BUD,ATH,OTP,SOF,ZAG,BEG,LJU,BTS,TLL,RIX,VNO,LCA,MLA,KEF,IST,LUX,SKP,TIA

# Browser request delay range in seconds (random jitter).
SF_MIN_DELAY=2.0
SF_MAX_DELAY=5.0

# Google Flights region/language params.
SF_GL=IN
SF_HL=en

# Optional HTTP proxy for Playwright (leave blank to disable).
# SF_PROXY_URL=

# Days between each departure date search (lower = more thorough, slower).
SF_DATE_STEP_DAYS=2

# Set to "true" to show the browser window during scraping.
SF_HEADLESS=true
